# PASP Control Center Environment Configuration

# Security
SECRET_KEY=your-super-secret-key-change-in-production

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/pasp_control_center.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pasp_control_center

# Kubeconfig Storage
KUBECONFIG_STORAGE_PATH=./kubeconfigs

# MLFlow Integration (optional)
MLFLOW_BASE_URL=https://your-mlflow-server.example.com

# API Settings
API_V1_PREFIX=/api/v1

# Admin credentials for write access (view is open to all)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Logging Configuration (optional - defaults to INFO)
# Options: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO
