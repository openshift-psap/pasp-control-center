# PASP Control Center Backend Configuration

SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite+aiosqlite:///./pasp_control_center.db
KUBECONFIG_STORAGE_PATH=./kubeconfigs
MLFLOW_BASE_URL=

# Admin credentials for write access (view is open to all)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Logging Configuration (optional - defaults to INFO)
# Options: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO
